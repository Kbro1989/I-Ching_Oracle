  49: { name: 'Revolution', category: 'boundary', action: 'ASSERT', binary: '101011' },
  50: { name: 'The Cauldron', category: 'transformer', action: 'ADAPT', binary: '001101' },
  51: { name: 'The Arousing (Shock)', category: 'transformer', action: 'ASSERT', binary: '100001' },
  52: { name: 'Keeping Still', category: 'dissipator', action: 'WAIT', binary: '001011' },
  53: { name: 'Development', category: 'sovereign', action: 'ADAPT', binary: '100100' },
  54: { name: 'The Marrying Maiden', category: 'transformer', action: 'YIELD', binary: '001001' },
  55: { name: 'Abundance', category: 'dissipator', action: 'ASSERT', binary: '101100' },
  56: { name: 'The Wanderer', category: 'sovereign', action: 'ADAPT', binary: '001101' },
  57: { name: 'The Gentle (Wind)', category: 'sovereign', action: 'YIELD', binary: '010110' },
  58: { name: 'The Joyous (Lake)', category: 'transformer', action: 'ADAPT', binary: '011011' },
  59: { name: 'Dispersion', category: 'dissipator', action: 'WAIT', binary: '010011' },
  60: { name: 'Limitation', category: 'transformer', action: 'YIELD', binary: '110110' },
  61: { name: 'Inner Truth', category: 'sovereign', action: 'YIELD', binary: '101100' },
  62: { name: 'Small Preponderance', category: 'sovereign', action: 'ADAPT', binary: '011001' },
  63: { name: 'After Completion', category: 'dissipator', action: 'WAIT', binary: '101010' },
  64: { name: 'Before Completion', category: 'transformer', action: 'ADAPT', binary: '010101' },
};

const FORBIDDEN_ADJACENT = new Set([9, 14, 15, 17, 18, 22, 23, 31, 43, 44, 48, 52, 55, 56, 59, 61, 62, 63]);

// ─── State ───────────────────────────────────────────────────────
let ws = null;
let tick = 0;
let currentHex = 1;
let sessionId = null;
let threadId = null;
let temporalContext = 'present';
let emotionWeight = 0.5;
let phaseIndex = 0;
const phases = ['void', 'shadow', 'vortex', 'governor', 'collapse'];

// ─── DOM Elements ────────────────────────────────────────────────
const els = {
  tickCounter: document.getElementById('tickCounter'),
  statusDot: document.getElementById('statusDot'),
  statusText: document.getElementById('statusText'),
  hexGrid: document.getElementById('hexGrid'),
  currentHexBadge: document.getElementById('currentHexBadge'),
  phaseTracker: document.getElementById('phaseTracker'),
  phaseBadge: document.getElementById('phaseBadge'),
  voidEntropy: document.getElementById('voidEntropy'),
  causalConfidence: document.getElementById('causalConfidence'),
  phaseMultiplier: document.getElementById('phaseMultiplier'),
  continuityValue: document.getElementById('continuityValue'),
  continuityBar: document.getElementById('continuityBar'),
  stabilityValue: document.getElementById('stabilityValue'),
  stabilityBar: document.getElementById('stabilityBar'),
  coherenceValue: document.getElementById('coherenceValue'),
  coherenceBar: document.getElementById('coherenceBar'),
  driftValue: document.getElementById('driftValue'),
  driftBar: document.getElementById('driftBar'),
  sovereignValue: document.getElementById('sovereignValue'),
  sovereignBar: document.getElementById('sovereignBar'),
  persistenceValue: document.getElementById('persistenceValue'),
  actionValue: document.getElementById('actionValue'),
  categoryValue: document.getElementById('categoryValue'),
  personaModeBadge: document.getElementById('personaModeBadge'),
  cadenceBadge: document.getElementById('cadenceBadge'),
  cadenceValue: document.getElementById('cadenceValue'),
  cadenceProgress: document.getElementById('cadenceProgress'),
  prosodyCoherence: document.getElementById('prosodyCoherence'),
  prosodyChaos: document.getElementById('prosodyChaos'),
  prosodyDarkTone: document.getElementById('prosodyDarkTone'),
  prosodyWhimsy: document.getElementById('prosodyWhimsy'),
  coherenceProsodyBar: document.getElementById('coherenceProsodyBar'),
  chaosProsodyBar: document.getElementById('chaosProsodyBar'),
  darktoneProsodyBar: document.getElementById('darktoneProsodyBar'),
  whimsyProsodyBar: document.getElementById('whimsyProsodyBar'),
  threadTableBody: document.getElementById('threadTableBody'),
  threadCountBadge: document.getElementById('threadCountBadge'),
  crisisBanner: document.getElementById('crisisBanner'),
  crisisBadge: document.getElementById('crisisBadge'),
  shellDistance: document.getElementById('shellDistance'),
  projectedShell: document.getElementById('projectedShell'),
  voidReentry: document.getElementById('voidReentry'),
  crisisCount: document.getElementById('crisisCount'),
  globalModeBadge: document.getElementById('globalModeBadge'),
  avgContinuity: document.getElementById('avgContinuity'),
  avgStability: document.getElementById('avgStability'),
  avgCoherence: document.getElementById('avgCoherence'),
  activeSessions: document.getElementById('activeSessions'),
  queryInput: document.getElementById('queryInput'),
  submitBtn: document.getElementById('submitBtn'),
  emotionSlider: document.getElementById('emotionSlider'),
  emotionValue: document.getElementById('emotionValue'),
  layerSovereign: document.getElementById('layerSovereign'),
  layerBoundary: document.getElementById('layerBoundary'),
  layerTransformer: document.getElementById('layerTransformer'),
  layerDissipator: document.getElementById('layerDissipator'),
};

// ─── Build Hex Grid ──────────────────────────────────────────────
function buildHexGrid() {
  els.hexGrid.innerHTML = '';
  for (let i = 1; i <= 64; i++) {
    const hex = HEXAGRAMS[i];
    const cell = document.createElement('div');
    cell.className = `hex-cell ${hex.category}`;
    cell.dataset.id = i;
    cell.textContent = i;

    if (FORBIDDEN_ADJACENT.has(i)) {
      cell.classList.add('forbidden-adjacent');
    }

    const tooltip = document.createElement('div');
    tooltip.className = 'hex-tooltip';
    tooltip.textContent = `#${i} ${hex.name}`;
    cell.appendChild(tooltip);

    cell.addEventListener('click', () => {
      currentHex = i;
      updateHexHighlight();
    });

    els.hexGrid.appendChild(cell);
  }
  updateHexHighlight();
}

function updateHexHighlight() {
  document.querySelectorAll('.hex-cell').forEach(cell => {
    cell.classList.toggle('current', parseInt(cell.dataset.id) === currentHex);
  });
  const hex = HEXAGRAMS[currentHex];
  els.currentHexBadge.textContent = `#${currentHex} ${hex.name}`;
}

// ─── WebSocket ───────────────────────────────────────────────────
function connectWS() {
  ws = new WebSocket(WS_URL);

  ws.onopen = () => {
    els.statusDot.classList.remove('disconnected');
    els.statusText.textContent = 'CONNECTED';
  };

  ws.onmessage = (event) => {
    const msg = JSON.parse(event.data);
    handleWSMessage(msg);
  };

  ws.onclose = () => {
    els.statusDot.classList.add('disconnected');
    els.statusText.textContent = 'RECONNECTING';
    setTimeout(connectWS, 3000);
  };

  ws.onerror = () => {
    els.statusDot.classList.add('disconnected');
    els.statusText.textContent = 'ERROR';
  };
}

function handleWSMessage(msg) {
  switch (msg.type) {
    case 'session':
      sessionId = msg.session_id;
      threadId = msg.thread_id;
      tick = msg.tick;
      break;
    case 'heartbeat':
      tick = msg.tick;
      updateHeartbeat(msg);
      break;
    case 'collapse':
      currentHex = msg.hexagram_id;
      updateHexHighlight();
      updateCollapse(msg);
      break;
    case 'crisis':
      showCrisis(msg);
      break;
    case 'response':
      showResponse(msg);
      break;
    case 'drift':
      updateDrift(msg);
      break;
    case 'continuity':
      updateContinuity(msg);
      break;
  }
}

function updateHeartbeat(msg) {
  els.tickCounter.textContent = msg.tick;
  if (msg.current_hex) currentHex = msg.current_hex;
  updateHexHighlight();
}

function updateDrift(msg) {
  if (msg.shell_distance !== undefined) els.shellDistance.textContent = msg.shell_distance;
  if (msg.projected_shell !== undefined) els.projectedShell.textContent = msg.projected_shell;
  // Use entropy delta as a proxy for void entropy if not provided
  if (msg.drift_vector?.entropy_delta !== undefined) {
    els.voidEntropy.textContent = Math.abs(msg.drift_vector.entropy_delta).toFixed(3);
  }
}

function updateContinuity(msg) {
  if (msg.continuity_score !== undefined) updateMetric('continuity', msg.continuity_score);
  if (msg.stability_score !== undefined) updateMetric('stability', msg.stability_score);
  if (msg.coherence_index !== undefined) updateMetric('coherence', msg.coherence_index);
  if (msg.drift_velocity !== undefined) updateMetric('drift', msg.drift_velocity);
  if (msg.sovereign_ratio !== undefined) updateMetric('sovereign', msg.sovereign_ratio);
  
  if (msg.persistence_countdown !== undefined) {
    els.persistenceValue.textContent = msg.persistence_countdown + ' ticks';
  }
  
  const globalMode = msg.continuity_score < 0.5 ? 'DELIBERATION' : msg.continuity_score > 0.8 ? 'EXPLORATION' : 'NORMAL';
  els.globalModeBadge.textContent = globalMode;
  els.avgContinuity.textContent = (msg.continuity_score || 0).toFixed(2);
  els.avgStability.textContent = (msg.stability_score || 0).toFixed(2);
  els.avgCoherence.textContent = (msg.coherence_index || 0).toFixed(2);
  
  // Prosody estimation (actual values come in response, but this keeps bars alive)
  const mode = msg.persona_mode || 'transformer';
  const prosody = {
    sovereign: { coherence: 1.0, chaos: 0.0, darkTone: 0.0, whimsy: 0.0 },
    boundary: { coherence: 0.7, chaos: 0.3, darkTone: 0.2, whimsy: 0.1 },
    transformer: { coherence: 0.5, chaos: 0.5, darkTone: 0.1, whimsy: 0.6 },
    dissipator: { coherence: 0.1, chaos: 0.9, darkTone: 0.5, whimsy: 0.2 },
  }[mode] || { coherence: 0.5, chaos: 0.5, darkTone: 0.1, whimsy: 0.6 };

  els.prosodyCoherence.textContent = prosody.coherence.toFixed(2);
  els.prosodyChaos.textContent = prosody.chaos.toFixed(2);
  els.prosodyDarkTone.textContent = prosody.darkTone.toFixed(2);
  els.prosodyWhimsy.textContent = prosody.whimsy.toFixed(2);
  els.coherenceProsodyBar.style.width = (prosody.coherence * 100) + '%';
  els.chaosProsodyBar.style.width = (prosody.chaos * 100) + '%';
  els.darktoneProsodyBar.style.width = (prosody.darkTone * 100) + '%';
  els.whimsyProsodyBar.style.width = (prosody.whimsy * 100) + '%';
}

function updateCollapse(msg) {
  els.causalConfidence.textContent = msg.fidelity?.toFixed(3) || '0.000';
  els.phaseMultiplier.textContent = msg.phase_multiplier?.toFixed(3) || '1.000';
  els.actionValue.textContent = msg.action || 'ASSERT';
  els.categoryValue.textContent = msg.category?.toUpperCase() || 'SOVEREIGN';

  const catColors = {
    sovereign: 'var(--accent-gold)',
    boundary: 'var(--accent-amber)',
    transformer: 'var(--accent-teal)',
    dissipator: 'var(--accent-void)',
  };
  els.actionValue.style.color = catColors[msg.category] || 'var(--accent-gold)';
  els.categoryValue.style.color = catColors[msg.category] || 'var(--accent-gold)';
  els.personaModeBadge.textContent = msg.category?.toUpperCase() || 'SOVEREIGN';
}

function updateMetric(name, value) {
  const elValue = document.getElementById(name + 'Value');
  const elBar = document.getElementById(name + 'Bar');
  if (elValue) elValue.textContent = value.toFixed(3);
  if (elBar) {
    elBar.style.width = (value * 100) + '%';
    elBar.style.background = value > 0.7 ? 'var(--accent-gold)'
      : value > 0.5 ? 'var(--accent-amber)'
      : value > 0.3 ? 'var(--accent-teal)'
      : 'var(--accent-void)';
  }
}

// ─── Phase Animation ─────────────────────────────────────────────
function animatePhase() {
  const steps = els.phaseTracker.querySelectorAll('.phase-step');
  steps.forEach((step, i) => {
    step.classList.toggle('active', i === phaseIndex);
    step.classList.toggle('completed', i < phaseIndex);
  });
  els.phaseBadge.textContent = phases[phaseIndex].toUpperCase();

  phaseIndex = (phaseIndex + 1) % phases.length;
}

// ─── Cadence Ring ────────────────────────────────────────────────
let cadenceProgress = 0;
function animateCadence() {
  cadenceProgress += 2;
  if (cadenceProgress > 113) cadenceProgress = 0;
  els.cadenceProgress.style.strokeDashoffset = 113 - cadenceProgress;
}

// ─── Crisis ─────────────────────────────────────────────────────
function showCrisis(msg) {
  els.crisisBanner.classList.add('visible', 'level-' + msg.level);
  els.crisisBanner.textContent = `CRISIS LEVEL ${msg.level} — ${msg.response?.toUpperCase() || 'FORBIDDEN STATE PROXIMITY'}`;
  els.crisisBadge.textContent = 'LEVEL ' + msg.level;
  els.crisisBadge.style.background = msg.level >= 3 ? 'var(--accent-red)' : 'var(--accent-amber)';
  els.crisisBadge.style.color = 'white';

  if (msg.level < 2) {
    setTimeout(() => {
      els.crisisBanner.classList.remove('visible');
    }, 5000);
  }
}

// ─── Response Layers ────────────────────────────────────────────
function showResponse(msg) {
  const layers = msg.layers;
  if (layers.sovereign) {
    els.layerSovereign.querySelector('.layer-content').textContent = layers.sovereign;
    els.layerSovereign.classList.remove('hidden');
  }
  if (layers.boundary) {
    els.layerBoundary.querySelector('.layer-content').textContent = layers.boundary;
    els.layerBoundary.classList.remove('hidden');
  } else {
    els.layerBoundary.classList.add('hidden');
  }
  if (layers.transformer) {
    els.layerTransformer.querySelector('.layer-content').textContent = layers.transformer;
    els.layerTransformer.classList.remove('hidden');
  } else {
    els.layerTransformer.classList.add('hidden');
  }
  if (layers.dissipator && layers.dissipator.length > 0) {
    els.layerDissipator.querySelector('.layer-content').innerHTML = layers.dissipator.join('<br>');
    els.layerDissipator.classList.remove('hidden');
  } else {
    els.layerDissipator.classList.add('hidden');
  }

  els.cadenceBadge.textContent = msg.cadence_ms + 'ms';
  els.cadenceValue.textContent = msg.cadence_ms + 'ms';
}

// ─── Query Submission ────────────────────────────────────────────
els.submitBtn.addEventListener('click', async () => {
  const text = els.queryInput.value.trim();
  if (!text) return;

  els.submitBtn.disabled = true;

  try {
    const response = await fetch(BASE_URL + '/oracle/consult', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        text,
        emotion: emotionWeight,
        temporal_context: temporalContext,
        session_id: sessionId,
      }),
    });

    const data = await response.json();
    showResponse(data);
  } catch (err) {
    console.error('Query failed:', err);
  } finally {
    els.submitBtn.disabled = false;
  }
});

els.queryInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    els.submitBtn.click();
  }
});

// ─── Temporal Toggle ─────────────────────────────────────────────
document.querySelectorAll('.temporal-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.temporal-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    temporalContext = btn.dataset.context;
  });
});

// ─── Emotion Slider ──────────────────────────────────────────────
els.emotionSlider.addEventListener('input', (e) => {
  emotionWeight = parseInt(e.target.value) / 100;
  els.emotionValue.textContent = emotionWeight.toFixed(2);
});

// ─── Thread Monitor (simulated for demo) ───────────────────────
function updateThreadMonitor() {
  const threads = [
    {
      id: threadId || '—',
      hex: currentHex,
      category: HEXAGRAMS[currentHex].category,
      continuity: parseFloat(els.continuityValue.textContent) || 1.0,
      drift: parseFloat(els.driftValue.textContent) || 0,
      status: 'active',
    }
  ];

  els.threadTableBody.innerHTML = threads.map(t => `
    <tr>
      <td>${t.id.slice(0, 8)}...</td>
      <td>#${t.hex}</td>
      <td><span style="color:var(--accent-${t.category === 'sovereign' ? 'gold' : t.category === 'boundary' ? 'amber' : t.category === 'transformer' ? 'teal' : 'void'})">${t.category}</span></td>
      <td>${t.continuity.toFixed(3)}</td>
      <td>${t.drift.toFixed(3)}</td>
      <td><span class="thread-status ${t.status}">${t.status}</span></td>
    </tr>
  `).join('');

  els.threadCountBadge.textContent = threads.length + ' thread' + (threads.length !== 1 ? 's' : '');
}

// ─── Init ────────────────────────────────────────────────────────
buildHexGrid();
connectWS();
drawLand();
initModel();

// 640ms beat — real telemetry only
setInterval(() => {
  animateCadence();
}, 640);

// Phase animation (128ms per phase = 640ms total)
setInterval(animatePhase, 128);

// Thread monitor update
setInterval(updateThreadMonitor, 2000);
</script>
</body>
</html>