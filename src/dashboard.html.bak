</div>

<script>
// ─── World Patch / Model Patch ───────────────────────────────────
(() => {
  const assetUrl = 'C:\\Users\\krist\\Downloads\\1,50,1,1.glb';
  const sector = { x: 2064, y: 3456 };

  function setStatus(id, text) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function drawLand() {
    setStatus('worldStatus', 'Land: rendering');
    const canvas = document.getElementById('landCanvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#111';
    ctx.fillRect(0, 90, canvas.width, 40);
    ctx.strokeStyle = '#333';
    ctx.strokeRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#777';
    ctx.font = '12px monospace';
    ctx.fillText('patch ' + sector.x + ',' + sector.y, 8, 18);
    setStatus('worldStatus', 'Land: shown');
  }

  async function initModel(Three) {
    setStatus('modelStatus', 'Avatar: loading');
    const canvas = document.getElementById('modelCanvas');
    if (!canvas) return;
    const renderer = new Three.WebGLRenderer({ canvas, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.setClearColor(0x000000, 1);
    renderer.setSize(canvas.clientWidth, canvas.clientHeight);
    const scene = new Three.Scene();
    const camera = new Three.PerspectiveCamera(55, canvas.clientWidth / canvas.clientHeight, 0.1, 100);
    camera.position.set(0, 1.4, 2.2);
    camera.lookAt(0, 0.6, 0);

    const orbit = new Three.OrbitControls(camera, canvas);
    orbit.target.set(0, 0.6, 0);
    orbit.update();

    let root = scene;
    function setAvatarRoot(node) { root = node || scene; }

    function tickFrame() {
      requestAnimationFrame(tickFrame);
      if (orbit) orbit.update();
      renderer.render(scene, camera);
    }

    const light = new Three.DirectionalLight(0xffffff, 2.2);
    light.position.set(2, 4, 2);
    scene.add(light);
    scene.add(new Three.AmbientLight(0xffffff, 0.6));

    const loader = new Three.GLTFLoader();
    const geo = new Three.SphereGeometry(0.45, 64, 64);
    const mat = new Three.MeshStandardMaterial({ color: 0xd4a843, metalness: 0.15, roughness: 0.35 });
    const placeholder = new Three.Mesh(geo, mat);
    placeholder.position.set(0, 0.6, 0);
    placeholder.name = 'oracle_anchor';
    scene.add(placeholder);

    const proxy = {
      set position(v) { placeholder.position.set(v.x ?? 0, v.y ?? 0, v.z ?? 0); },
      get position() { return placeholder.position; },
      dispose() { placeholder.geometry.dispose(); (placeholder.material as any).dispose?.(); }
    };

    setAvatarRoot(proxy);
    tickFrame();

    try {
      const doc = await loader.loadAsync(assetUrl);
      const node = doc.scene;
      node.position.set(0, 0, 0);
      scene.add(node);
      placeholder.visible = false;
      setAvatarRoot(node);
      setStatus('modelStatus', 'Avatar: loaded');
    } catch (e) {
      console.warn('GLB load failed, using placeholder:', e);
      setStatus('modelStatus', 'Avatar: placeholder');
    }
  }

  window.__worldPatch = { drawLand, initModel, setAvatarRoot, assetUrl };
})();
</script>

