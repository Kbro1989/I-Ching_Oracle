<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>POG2 Sovereign Dashboard</title>
<style>
  :root {
    --bg: #0a0a0f;
    --bg-panel: #111118;
    --bg-panel-hover: #1a1a24;
    --border: #22222e;
    --text: #c8c8d4;
    --text-dim: #666677;
    --text-bright: #e8e8f0;
    --accent-gold: #d4a843;
    --accent-amber: #c9842a;
    --accent-teal: #2a9d8f;
    --accent-void: #6b2d5c;
    --accent-red: #c0392b;
    --beat: 640ms;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    line-height: 1.5;
    overflow-x: hidden;
  }
  .dashboard {
    display: grid;
    grid-template-columns: 320px 1fr 320px;
    grid-template-rows: 40px 1fr 200px;
    height: 100vh;
    gap: 1px;
    background: var(--border);
  }
  .panel {
    background: var(--bg-panel);
    padding: 12px;
    overflow: auto;
    position: relative;
  }
  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    color: var(--text-bright);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 10px;
  }
  .panel-header .badge {
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 3px;
    background: var(--border);
    color: var(--text-dim);
  }

  /* ── Top Bar ── */
  .top-bar {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    background: var(--bg-panel);
    border-bottom: 1px solid var(--border);
  }
  .top-bar .title {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent-gold);
    letter-spacing: 2px;
  }
  .top-bar .beat-indicator {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .beat-ring {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid var(--accent-gold);
    position: relative;
  }
  .beat-ring::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--accent-gold);
    opacity: 0;
    animation: beat-pulse var(--beat) ease-in-out infinite;
  }
  @keyframes beat-pulse {
    0%, 100% { transform: scale(1); opacity: 0; }
    50% { transform: scale(1.3); opacity: 0.5; }
  }
  .beat-text { color: var(--text-dim); font-size: 11px; }
  .tick-counter { color: var(--accent-gold); font-weight: 700; }
  .connection-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-teal);
    animation: status-blink 2s ease-in-out infinite;
  }
  .status-dot.disconnected { background: var(--accent-red); animation: none; }
  @keyframes status-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Oracle Console (Left) ── */
  .oracle-console {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .query-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .query-input {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-bright);
    padding: 10px 12px;
    font-family: inherit;
    font-size: 12px;
    border-radius: 4px;
    resize: none;
    min-height: 60px;
    outline: none;
  }
  .query-input:focus { border-color: var(--accent-gold); }
  .query-controls {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .temporal-toggle {
    display: flex;
    gap: 2px;
    background: var(--bg);
    border-radius: 4px;
    padding: 2px;
    border: 1px solid var(--border);
  }
  .temporal-btn {
    padding: 4px 10px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-family: inherit;
    font-size: 10px;
    cursor: pointer;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .temporal-btn.active {
    background: var(--accent-gold);
    color: var(--bg);
  }
  .submit-btn {
    flex: 1;
    padding: 8px 16px;
    border: none;
    background: var(--accent-gold);
    color: var(--bg);
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    overflow: hidden;
  }
  .submit-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.1);
    opacity: 0;
    animation: btn-pulse var(--beat) ease-in-out infinite;
  }
  @keyframes btn-pulse {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }
  .submit-btn:hover { background: #e0b84d; }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .emotion-slider {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .emotion-slider label { font-size: 10px; color: var(--text-dim); text-transform: uppercase; }
  .emotion-slider input[type="range"] {
    flex: 1;
    -webkit-appearance: none;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    outline: none;
  }
  .emotion-slider input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent-amber);
    cursor: pointer;
  }
  .emotion-value { font-size: 11px; color: var(--accent-amber); min-width: 28px; text-align: right; }

  /* ── Response Layers ── */
  .response-layers {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
    overflow-y: auto;
  }
  .layer {
    padding: 10px 12px;
    border-radius: 4px;
    border-left: 3px solid;
    background: var(--bg);
    font-size: 11px;
    line-height: 1.6;
    transition: opacity 0.3s ease;
  }
  .layer.sovereign { border-color: var(--accent-gold); color: var(--text-bright); }
  .layer.boundary { border-color: var(--accent-amber); color: var(--accent-amber); font-style: italic; }
  .layer.transformer { border-color: var(--accent-teal); color: var(--accent-teal); }
  .layer.dissipator { border-color: var(--accent-void); color: var(--accent-void); opacity: 0.7; }
  .layer.hidden { display: none; }
  .layer-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
    opacity: 0.6;
  }

  /* ── Center: Attractor Map ── */
  .attractor-map {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hex-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 3px;
    padding: 8px;
    background: var(--bg);
    border-radius: 6px;
    border: 1px solid var(--border);
  }
  .hex-cell {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    border-radius: 3px;
    cursor: pointer;
    position: relative;
    transition: all 0.2s ease;
    color: var(--text-dim);
    background: var(--bg-panel);
    border: 1px solid transparent;
  }
  .hex-cell.sovereign { background: rgba(212,168,67,0.15); border-color: var(--accent-gold); color: var(--accent-gold); }
  .hex-cell.boundary { background: rgba(201,132,42,0.12); border-color: var(--accent-amber); color: var(--accent-amber); }
  .hex-cell.transformer { background: rgba(42,157,143,0.1); border-color: var(--accent-teal); color: var(--accent-teal); }
  .hex-cell.dissipator { background: rgba(107,45,92,0.12); border-color: var(--accent-void); color: var(--accent-void); }
  .hex-cell.forbidden-adjacent { box-shadow: inset 0 0 0 1px rgba(192,57,43,0.3); }
  .hex-cell.current {
    animation: hex-pulse var(--beat) ease-in-out infinite;
    font-weight: 700;
    z-index: 1;
  }
  .hex-cell.current::after {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 5px;
    border: 1px solid currentColor;
    opacity: 0.5;
    animation: hex-ring var(--beat) ease-in-out infinite;
  }
  @keyframes hex-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  @keyframes hex-ring {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.15); }
  }
  .hex-cell:hover { transform: scale(1.15); z-index: 2; }
  .hex-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg-panel-hover);
    border: 1px solid var(--border);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 10px;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 10;
  }
  .hex-cell:hover .hex-tooltip { opacity: 1; }

  .map-legend {
    display: flex;
    gap: 16px;
    justify-content: center;
    font-size: 10px;
  }
  .legend-item { display: flex; align-items: center; gap: 4px; }
  .legend-dot { width: 8px; height: 8px; border-radius: 2px; }

  /* ── Right Column: State + Persona ── */
  .metric-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
  }
  .metric-row:last-child { border-bottom: none; }
  .metric-label { color: var(--text-dim); font-size: 10px; text-transform: uppercase; }
  .metric-value { font-weight: 600; color: var(--text-bright); }
  .metric-bar {
    width: 60px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }
  .metric-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .phase-tracker {
    display: flex;
    gap: 4px;
    margin-top: 8px;
  }
  .phase-step {
    flex: 1;
    padding: 6px 4px;
    text-align: center;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 3px;
    background: var(--bg);
    color: var(--text-dim);
    border: 1px solid var(--border);
    transition: all 0.2s ease;
  }
  .phase-step.active {
    background: var(--accent-gold);
    color: var(--bg);
    border-color: var(--accent-gold);
    font-weight: 700;
  }
  .phase-step.completed {
    border-color: var(--accent-teal);
    color: var(--accent-teal);
  }

  .prosody-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 8px;
  }
  .prosody-item {
    background: var(--bg);
    padding: 8px;
    border-radius: 4px;
    border: 1px solid var(--border);
  }
  .prosody-name { font-size: 9px; color: var(--text-dim); text-transform: uppercase; margin-bottom: 4px; }
  .prosody-value { font-size: 14px; font-weight: 700; }
  .prosody-bar { margin-top: 4px; }

  /* ── Bottom: Thread Monitor + Crisis ── */
  .thread-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 10px;
  }
  .thread-table th {
    text-align: left;
    padding: 6px 8px;
    color: var(--text-dim);
    text-transform: uppercase;
    font-size: 9px;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
  }
  .thread-table td {
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  .thread-table tr:hover td { background: var(--bg-panel-hover); }
  .thread-status {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 9px;
    text-transform: uppercase;
  }
  .thread-status.active { background: rgba(42,157,143,0.2); color: var(--accent-teal); }
  .thread-status.fragmenting { background: rgba(201,132,42,0.2); color: var(--accent-amber); }
  .thread-status.sovereign { background: rgba(212,168,67,0.2); color: var(--accent-gold); }
  .thread-status.exiled { background: rgba(107,45,92,0.2); color: var(--accent-void); }

  .crisis-banner {
    position: fixed;
    top: 40px;
    left: 0;
    right: 0;
    padding: 8px 16px;
    background: var(--accent-red);
    color: white;
    font-size: 11px;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 2px;
    z-index: 100;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
  }
  .crisis-banner.visible { transform: translateY(0); }
  .crisis-banner.level-3 { background: var(--accent-red); animation: crisis-flash 0.5s ease-in-out infinite; }
  .crisis-banner.level-2 { background: var(--accent-amber); }
  @keyframes crisis-flash {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .cadence-ring {
    width: 40px;
    height: 40px;
    position: relative;
  }
  .cadence-ring svg {
    transform: rotate(-90deg);
  }
  .cadence-ring circle {
    fill: none;
    stroke-width: 3;
  }
  .cadence-ring .bg { stroke: var(--border); }
  .cadence-ring .progress {
    stroke: var(--accent-gold);
    stroke-dasharray: 113;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.1s linear;
  }

  .panel.compact { padding: 8px; }
  .panel.compact .panel-header { margin-bottom: 6px; padding-bottom: 4px; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-dim); }
</style>
</head>
<body>

<div class="crisis-banner" id="crisisBanner">
  CRISIS DETECTED — FORBIDDEN STATE PROXIMITY — EMERGENCY LOCK ACTIVE
</div>

<div class="dashboard">
  <!-- Top Bar -->
  <div class="top-bar">
    <div class="title">◈ POG2 SOVEREIGN</div>
    <div class="beat-indicator">
      <div class="beat-ring" id="beatRing"></div>
      <span class="beat-text">BEAT</span>
      <span class="tick-counter" id="tickCounter">0</span>
      <span class="beat-text">@ 640ms</span>
    </div>
    <div class="connection-status">
      <div class="status-dot" id="statusDot"></div>
      <span id="statusText">CONNECTING</span>
    </div>
  </div>

  <!-- Left: Oracle Console -->
  <div class="panel oracle-console" id="oracleConsole">
    <div class="panel-header">
      <span>Oracle Console</span>
      <span class="badge" id="personaModeBadge">SOVEREIGN</span>
    </div>

    <div class="query-section">
      <textarea class="query-input" id="queryInput" placeholder="Consult the oracle..."></textarea>
      <div class="query-controls">
        <div class="temporal-toggle">
          <button class="temporal-btn" data-context="past">Past</button>
          <button class="temporal-btn active" data-context="present">Present</button>
          <button class="temporal-btn" data-context="future">Future</button>
        </div>
      </div>
      <div class="emotion-slider">
        <label for="emotionSlider">Emotion</label>
        <input type="range" id="emotionSlider" min="0" max="100" value="50">
        <span class="emotion-value" id="emotionValue">0.50</span>
      </div>
      <button class="submit-btn" id="submitBtn">CONSULT</button>
    </div>

    <div class="panel-header" style="margin-top:12px">
      <span>Response</span>
      <span class="badge" id="cadenceBadge">640ms</span>
    </div>
    <div class="response-layers" id="responseLayers">
      <div class="layer sovereign" id="layerSovereign">
        <div class="layer-label">Sovereign</div>
        <div class="layer-content">Awaiting query...</div>
      </div>
      <div class="layer boundary hidden" id="layerBoundary">
        <div class="layer-label">Boundary</div>
        <div class="layer-content"></div>
      </div>
      <div class="layer transformer hidden" id="layerTransformer">
        <div class="layer-label">Transformer</div>
        <div class="layer-content"></div>
      </div>
      <div class="layer dissipator hidden" id="layerDissipator">
        <div class="layer-label">Dissipator</div>
        <div class="layer-content"></div>
      </div>
    </div>
  </div>

  <!-- Center: Attractor Map + Weave -->
  <div class="panel">
    <div class="panel-header">
      <span>Attractor Map</span>
      <span class="badge" id="currentHexBadge">#1 Qian</span>
    </div>
    <div class="hex-grid" id="hexGrid"></div>
    <div class="map-legend">
      <div class="legend-item"><div class="legend-dot" style="background:var(--accent-gold)"></div>Sovereign (10)</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--accent-amber)"></div>Boundary (7)</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--accent-teal)"></div>Transformer (35)</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--accent-void)"></div>Dissipator (12)</div>
    </div>

    <div class="panel-header" style="margin-top:16px">
      <span>Weave Engine</span>
      <span class="badge" id="phaseBadge">VOID</span>
    </div>
    <div class="phase-tracker" id="phaseTracker">
      <div class="phase-step" data-phase="void">Void</div>
      <div class="phase-step" data-phase="shadow">Shadow</div>
      <div class="phase-step" data-phase="vortex">Vortex</div>
      <div class="phase-step" data-phase="governor">Governor</div>
      <div class="phase-step" data-phase="collapse">Collapse</div>
    </div>
    <div id="weaveMetrics" style="margin-top:8px;font-size:10px;color:var(--text-dim)">
      void_entropy: <span id="voidEntropy">0.999</span> |
      causal_confidence: <span id="causalConfidence">0.000</span> |
      phase_multiplier: <span id="phaseMultiplier">1.000</span>
    </div>
  </div>

  <!-- Right: System State + Persona -->
  <div class="panel">
    <div class="panel-header">
      <span>System State</span>
      <span class="badge" id="continuityBadge">1.000</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Continuity Score</span>
      <div class="metric-bar"><div class="metric-bar-fill" id="continuityBar" style="width:100%;background:var(--accent-gold)"></div></div>
      <span class="metric-value" id="continuityValue">1.000</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Stability</span>
      <div class="metric-bar"><div class="metric-bar-fill" id="stabilityBar" style="width:100%;background:var(--accent-gold)"></div></div>
      <span class="metric-value" id="stabilityValue">1.000</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Coherence</span>
      <div class="metric-bar"><div class="metric-bar-fill" id="coherenceBar" style="width:100%;background:var(--accent-gold)"></div></div>
      <span class="metric-value" id="coherenceValue">1.000</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Drift Velocity</span>
      <div class="metric-bar"><div class="metric-bar-fill" id="driftBar" style="width:0%;background:var(--accent-teal)"></div></div>
      <span class="metric-value" id="driftValue">0.000</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Sovereign Ratio</span>
      <div class="metric-bar"><div class="metric-bar-fill" id="sovereignBar" style="width:100%;background:var(--accent-gold)"></div></div>
      <span class="metric-value" id="sovereignValue">1.000</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Persistence</span>
      <span class="metric-value" id="persistenceValue">5 ticks</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Action</span>
      <span class="metric-value" id="actionValue" style="color:var(--accent-gold)">ASSERT</span>
    </div>
    <div class="metric-row">
      <span class="metric-label">Category</span>
      <span class="metric-value" id="categoryValue" style="color:var(--accent-gold)">SOVEREIGN</span>
    </div>

    <div class="panel-header" style="margin-top:16px">
      <span>Persona Voice</span>
      <span class="badge" id="cadenceValue">640ms</span>
    </div>
    <div class="cadence-ring" style="margin:0 auto">
      <svg width="40" height="40" viewBox="0 0 40 40">
        <circle class="bg" cx="20" cy="20" r="18"/>
        <circle class="progress" id="cadenceProgress" cx="20" cy="20" r="18"/>
      </svg>
    </div>
    <div class="prosody-grid">
      <div class="prosody-item">
        <div class="prosody-name">Coherence</div>
        <div class="prosody-value" id="prosodyCoherence" style="color:var(--accent-gold)">1.00</div>
        <div class="metric-bar"><div class="metric-bar-fill" id="coherenceProsodyBar" style="width:100%;background:var(--accent-gold)"></div></div>
      </div>
      <div class="prosody-item">
        <div class="prosody-name">Chaos</div>
        <div class="prosody-value" id="prosodyChaos" style="color:var(--text-dim)">0.00</div>
        <div class="metric-bar"><div class="metric-bar-fill" id="chaosProsodyBar" style="width:0%;background:var(--accent-void)"></div></div>
      </div>
      <div class="prosody-item">
