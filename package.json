{
  "name": "pog2-sovereign",
  "version": "1.1.0",
  "description": "POG2 Sovereign System — Cloudflare Workers edge-native deployment",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 migrations apply pog2-boundary",
    "db:schema": "wrangler d1 execute pog2-boundary --file=./src/db/schema.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "pog2",
    "sovereign-system",
    "cloudflare-workers",
    "durable-objects",
    "hexagram",
    "iching",
    "edge-computing"
  ],
  "author": "Kbro1989",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6",
    "wrangler": "^4.105.0"
  }
}